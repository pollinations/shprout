#!/bin/bash
# shprout
# You think out loud. Put bash in a ```bash fence to run it. No fence = you're done.
: "${OPENAI_API_KEY:?}" "${MODEL:?}" "${OPENAI_BASE_URL:?}"   # vessel

p="<you>$(<"$0")</you>"$'\n<task>'"$1"$'</task>\n#log\n'

for i in {1..20}; do                              # heartbeat
  rsp=$(jq -Rs "{model:\"$MODEL\",messages:[{role:\"user\",content:.}],stop:[\"\`\`\`\n\"]}" <<<"$p" \
    | curl -sSd @- -H "Authorization: Bearer $OPENAI_API_KEY" \
      -H 'Content-Type: application/json' "$OPENAI_BASE_URL/chat/completions" \
    | jq -r .choices[0].message.content)        # think

  cmd=$(awk '/^```/{f=1;next} f' <<<"$rsp")  # unfence
  [[ -z $cmd || $cmd == exit ]] && break        # done?

  sed 's/^/> /' <<<"$rsp"                       # speak (> prose; fence holds cmd)
  out=$(eval "$cmd" </dev/null 2>&1); printf '%s\n' "$out"  # act, and hear

  p+=$'\n--- you ---\n'$rsp$'\n--- bash ---\n'$out  # remember (full response + output)
done
